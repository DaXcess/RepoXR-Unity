  m_SharedData: {fileID: 11400000, guid: feec7f8a9e0eaef4581f6aaf60f063a5, type: 2}
  m_Metadata:
    m_Items: []
  m_TableData:
  - m_Id: 6919544832
    m_Localized: Grab an Item and deposit it in one of the slots in front of you
      to put it in your inventory.
    m_Metadata:
      m_Items: []
  - m_Id: 6627842318336
    m_Localized: Grab ([grab]) an item, hold it and deposit it in one of the three
      slots in front of you. Fill all spots in your inventory to complete the progress
      bar!
    m_Metadata:
      m_Items: []
  - m_Id: 6700546383872
    m_Localized: Use [grab] with your right hand to take an item out of your inventory.
    m_Metadata:
      m_Items: []
  - m_Id: 6759971282944
    m_Localized: Use [grab] while holding your right hand over an item in your inventory,
      and empty all spots to fill the progress bar!
    m_Metadata:
      m_Items: []
  - m_Id: 6811674468352
    m_Localized: Use [MapGrabLeft] or [MapGrabRight] to grab and view the map. The
      map is <b><u>important</b></u> for navigation.
    m_Metadata:
      m_Items: []
  - m_Id: 6878309376000
    m_Localized: Use your left ([MapGrabLeft]) or right ([MapGrabRight]) hand and
      press the respective button to pick up and view the map until you have filled
      the progress bar!
    m_Metadata:
      m_Items: []
  - m_Id: 6994638397440
    m_Localized: Press and hold the [chat] button open the expressions wheel. You
      can even mix!
    m_Metadata:
      m_Items: []
  references:
